generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // change to "postgresql" in production
  url      = env("DATABASE_URL")
}

model Campsite {
  id                     Int      @id @default(autoincrement())

  dataset                String
  sourceId               String

  // Core display/search fields
  name                   String
  place                  String?
  region                 String?
  campsiteCategory       String?
  introduction           String?
  access                 String?
  facilities             String?
  dogsAllowed            String?
  dogsAllowedBool        Boolean?

  // Landscape / activity tags (sourced from DOC GeoJSON)
  landscape              String?
  activities             String?

  // Search / derived flags from DOC facilities text
  hasToilets             Boolean?
  hasWater               Boolean?
  hasPower               Boolean?

  // Capacity
  numberOfPoweredSites   Int?
  numberOfUnpoweredSites Int?

  // Booking / permissions
  bookable              Boolean

  // Media / links
  staticLink            String?
  imageUrl              String?

  // Converted WGS84 coordinates (used by map/weather/distance)
  lat                    Float
  lon                    Float

  // Extra raw content for debugging / future UI
  properties             String?
  geometry               String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([dataset, sourceId])
  @@index([dataset])
  @@index([name])
  @@index([region])
  @@index([campsiteCategory])
  @@index([access])
  @@index([lat, lon])
}