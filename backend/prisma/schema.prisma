generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql" // neon
  // Pooled URL for the app (Neon *-pooler* host). Migrations need a direct session — see directUrl.
  url       = env("DATABASE_URL")
  // Non-pooler connection for `prisma migrate` (advisory locks fail via PgBouncer). Same as DATABASE_URL if you are not using Neon’s pooler.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                     Int      @id @default(autoincrement())
  email                  String   @unique
  username               String?
  passwordHash           String
  emailVerified          Boolean  @default(false)
  verificationToken      String?  @unique
  verificationTokenExpiry DateTime?
  resetToken             String?  @unique
  resetTokenExpiry       DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  shortlistItems         ShortlistItem[]
  reviews                Review[]

  @@index([email])
}

model ShortlistItem {
  id         Int      @id @default(autoincrement())
  userId     Int
  campsiteId Int
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campsite   Campsite @relation(fields: [campsiteId], references: [id], onDelete: Cascade)

  @@unique([userId, campsiteId])
  @@index([userId])
}

model Campsite {
  id                     Int      @id @default(autoincrement())

  dataset                String
  sourceId               String

  // Core display/search fields
  name                   String
  place                  String?
  region                 String?
  campsiteCategory       String?
  introduction           String?
  access                 String?
  facilities             String?
  dogsAllowed            String?
  dogsAllowedBool        Boolean?

  // Landscape / activity tags (sourced from DOC GeoJSON)
  landscape              String?
  activities             String?

  // Search / derived flags from DOC facilities text
  hasToilets             Boolean?
  hasWater               Boolean?
  hasPower               Boolean?

  // Capacity
  numberOfPoweredSites   Int?
  numberOfUnpoweredSites Int?

  // Booking / permissions
  bookable              Boolean

  // Media / links
  staticLink            String?
  imageUrl              String?

  // Converted WGS84 coordinates (used by map/weather/distance)
  lat                    Float
  lon                    Float

  // Extra raw content for debugging / future UI
  properties             String?
  geometry               String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  shortlistItems         ShortlistItem[]
  reviews                Review[]

  @@unique([dataset, sourceId])
  @@index([dataset])
  @@index([name])
  @@index([region])
  @@index([campsiteCategory])
  @@index([access])
  @@index([lat, lon])
}

model Review {
  id         Int      @id @default(autoincrement())
  userId     Int
  campsiteId Int
  rating     Int
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campsite Campsite @relation(fields: [campsiteId], references: [id], onDelete: Cascade)

  @@unique([userId, campsiteId])
  @@index([campsiteId])
}