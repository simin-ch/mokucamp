# Copy to .env and fill in real values: cp .env.example .env

# Neon: use the pooled connection for DATABASE_URL (host contains "-pooler").
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct (non-pooler) URL for Prisma migrations — required on Render or migrate deploy can time out on pg_advisory_lock (P1002).
# In Neon Dashboard: copy the connection string that does NOT use the pooler, or remove "-pooler" from the hostname.
# Local Postgres / non-Neon: set to the same value as DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Email
# Local dev: leave EMAIL_SENDGRID_API_KEY empty → Ethereal (preview URLs in server logs).
EMAIL_SENDGRID_API_KEY=""
EMAIL_FROM="Mokucamp <no-reply@mokucamp.app>"
#
# Production (Render): set EMAIL_SENDGRID_API_KEY to your SendGrid API Key
# (Settings → API Keys → Mail Send permission).
# EMAIL_FROM must match a verified Single Sender or Domain in SendGrid.

# Used in email verification / reset links
FRONTEND_URL="http://localhost:5173"
