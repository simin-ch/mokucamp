# Copy to .env and fill in real values: cp .env.example .env

# Neon: for Render (or any host that runs `prisma migrate deploy` in build), prefer the
# direct / non-pooling connection string so migrations can take Postgres advisory locks.
# If you only use a *-pooler* URL here, migrate may fail with P1002.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

# Jest integration tests (Neon branch for test; use Direct connection, not pooler)
TEST_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Email
# Local dev: leave EMAIL_SENDGRID_API_KEY empty → Ethereal (preview URLs in server logs).
EMAIL_SENDGRID_API_KEY=""
EMAIL_FROM="Mokucamp <no-reply@mokucamp.app>"
#
# Production (Render): set EMAIL_SENDGRID_API_KEY to your SendGrid API Key
# (Settings → API Keys → Mail Send permission).
# EMAIL_FROM must match a verified Single Sender or Domain in SendGrid.

# Used in email verification / reset links
FRONTEND_URL="http://localhost:5173"
