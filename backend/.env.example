# Copy to .env and fill in real values: cp .env.example .env

DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Email — Nodemailer SMTP
# Local: leave EMAIL_USER empty → Ethereal (preview URLs in server logs).
EMAIL_HOST="smtp.ethereal.email"
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="Mokucamp <no-reply@mokucamp.app>"
#
# SendGrid (production / Render): replace email block with:
# EMAIL_HOST="smtp.sendgrid.net"
# EMAIL_PORT=587
# EMAIL_USER="apikey"
# EMAIL_PASS="<SendGrid API Key — Settings → API Keys>"
# EMAIL_FROM="Mokucamp <you@your-verified-sender-domain.com>"
# (Single Sender Verification or Domain Authentication in SendGrid — From must match.)

# Used in email verification / reset links
FRONTEND_URL="http://localhost:5173"
